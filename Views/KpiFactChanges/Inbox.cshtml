@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
  ViewData["Title"] = Localizer["ApprovalsInbox"];
}
<style>
  .appr-diff {
    color: #111;
  }

  .appr-card+.appr-card {
    margin-top: .75rem;
  }
</style>

<div class="container py-4">
  @section PageHeader {
    <div class="page-hero" style="background-image:url('@Url.Content("~/images/pic1.jpg")')">
      <div class="page-hero-content">
        <h1 class="page-title">@Localizer["ApprovalsInbox"]</h1>
      </div>
    </div>
  }

  <!-- antiforgery for AJAX -->
  <form id="af" class="d-none" method="post">@Html.AntiForgeryToken()</form>

  <div class="with-rails">
    <div class="d-flex gap-2 mb-3">
      <button class="btn btn-sm btn-primary" data-tab="pending">@Localizer["Pending"]</button>
      <button class="btn btn-sm btn-outline-secondary" data-tab="approved">@Localizer["Approved"]</button>
      <button class="btn btn-sm btn-outline-secondary" data-tab="rejected">@Localizer["Rejected"]</button>
      <button asp-admin-only class="btn btn-sm btn-outline-secondary"
              data-tab="editors">@Localizer["LatestSubmissions"]</button>
      <button class="btn btn-sm btn-outline-secondary ms-auto" id="refreshBtn">↻ @Localizer["Refresh"]</button>
    </div>

    <div id="apprBody" class="bg-white border rounded-3 p-3">
      <div class="text-muted small">Loading…</div>
    </div>
  </div>
</div>

<!-- Reject Modal (supports batch and single change) -->
<div class="modal fade" id="rejectModal" tabindex="-1" aria-labelledby="rejectLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content rounded-3">
      <div class="modal-header">
        <h5 class="modal-title" id="rejectLabel">@Localizer["Reject"]</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form id="rejectForm" method="post">
        @Html.AntiForgeryToken()
        <div class="modal-body">
          <input type="hidden" id="rej_changeId" name="changeId" />
          <input type="hidden" id="rej_batchId" name="batchId" />
          <div class="mb-3">
            <label class="form-label">@Localizer["Reason"]</label>
            <textarea class="form-control" id="rej_reason" name="reason" rows="3" required></textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">@Localizer["Cancel"]</button>
          <button class="btn btn-danger" type="submit">@Localizer["Reject"]</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Unified Details Modal (batch-wide overlay; falls back to single row if needed) -->
<div class="modal fade" id="detailsModal" tabindex="-1" aria-labelledby="detailsLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content rounded-3">
      <div class="modal-header">
        <div>
          <h5 class="modal-title" id="detailsLabel">@Localizer["ChangeDetails"]</h5>
          <div class="small text-muted" id="detailsSubtitle">—</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="border rounded p-2" style="height:360px">
          <canvas id="apprChart"></canvas>
        </div>

        <!-- simple summary -->
        <div class="row small mt-3" id="proposedSummary" style="row-gap:.25rem">
          <div class="col-6 col-md-3"><strong>@Localizer["ActualPointsCount"]</strong> <span
            id="pv_count_actual">—</span></div>
            <div class="col-6 col-md-3"><strong>@Localizer["TargetPointsCount"]</strong> <span
              id="pv_count_target">—</span></div>
              <div class="col-6 col-md-3"><strong>@Localizer["ForecastPointsCount"]</strong> <span
                id="pv_count_forecast">—</span></div>
                <div class="col-12 mt-2"><strong>@Localizer["Periods"]</strong> <span id="pv_periods">—</span></div>
              </div>

            </div>
            <div class="modal-footer">
              <button class="btn btn-outline-secondary" type="button" data-bs-dismiss="modal">@Localizer["Close"]</button>
            </div>
          </div>
        </div>
      </div>
      <!-- Latest Submissions Details Modal -->
      <div class="modal fade" id="editorDetailsModal" tabindex="-1" aria-labelledby="editorDetailsLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg">
          <div class="modal-content rounded-3">
            <div class="modal-header">
              <div>
                <h5 class="modal-title" id="editorDetailsLabel">@Localizer["IndicatorDetails"]</h5>
                <div class="small text-muted" id="editorDetailsSubtitle">—</div>
              </div>
              <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
              <div class="border rounded p-2" style="height:360px">
                <canvas id="editorApprChart"></canvas>
              </div>

              <div class="row small mt-3" style="row-gap:.4rem">
                @* <div class="col-6 col-md-3"><strong>Approved Actual:</strong> <span id="ed_approved_actual">—</span></div>
          <div class="col-6 col-md-3"><strong>Approved Target:</strong> <span id="ed_approved_target">—</span></div>
          <div class="col-6 col-md-3"><strong>Approved Forecast:</strong> <span id="ed_approved_forecast">—</span></div>
          <div class="col-6 col-md-3"><strong>Approved Status:</strong> <span id="ed_approved_status">—</span></div>

          <div class="col-6 col-md-3"><strong>Pending Actual:</strong> <span id="ed_pending_actual">—</span></div>
          <div class="col-6 col-md-3"><strong>Pending Target:</strong> <span id="ed_pending_target">—</span></div>
          <div class="col-6 col-md-3"><strong>Pending Forecast:</strong> <span id="ed_pending_forecast">—</span></div>
          <div class="col-6 col-md-3"><strong>Pending Status:</strong> <span id="ed_pending_status">—</span></div>

          <div class="col-6 col-md-3"><strong>Missing Actual:</strong> <span id="ed_missing_actual">—</span></div>
          <div class="col-6 col-md-3"><strong>Missing Target:</strong> <span id="ed_missing_target">—</span></div>
          <div class="col-6 col-md-3"><strong>Missing Forecast:</strong> <span id="ed_missing_forecast">—</span></div>
          <div class="col-6 col-md-3"><strong>Missing Status:</strong> <span id="ed_missing_status">—</span></div>

          <div class="col-12 mt-2"><strong>Pending periods:</strong> <span id="ed_periods_pending">—</span></div>
          <div class="col-12"><strong>Missing periods:</strong> <span id="ed_periods_missing">—</span></div> *@
              </div>
            </div>
            <div class="modal-footer">
              <h5 class="modal-title" id="editorDetailsLabel">@Localizer["IndicatorDetails"]</h5>
            </div>
          </div>
        </div>
      </div>
      @section Scripts {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
          const apprText = {
          loading: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Loading"].Value)),
          failedToLoad: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["FailedToLoad"].Value)),
          approve: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Approve"].Value)),
          reject: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Reject"].Value)),
          pending: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Pending"].Value)),
          approved: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Approved"].Value)),
          rejected: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Rejected"].Value)),
          details: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Localizer["Details"].Value)),
