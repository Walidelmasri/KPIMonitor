@model KPIMonitor.Models.ViewModels.PriorityMatrixVm
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
  ViewData["Title"] = Localizer["PriorityMatrix"];
}

<style>
  .pm-wrap { padding-block: 1rem 2rem; }

  /* ---- Matrix layout (2×2) ---- */
  .pm-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: auto auto;
    gap: 24px;
  }
  @@media (max-width: 992px){
    .pm-grid { grid-template-columns: 1fr; grid-template-rows: auto auto auto auto; }
  }

  .pm-grid::before,
  .pm-grid::after {
    content:"";
    position:absolute;
    background:#dee2e6;
    z-index:0;
  }
  .pm-grid::before {
    top:0; left:50%; width:1px; height:100%; transform:translateX(-0.5px);
  }
  .pm-grid::after {
    left:0; top:50%; height:1px; width:100%; transform:translateY(-0.5px);
  }
  @@media (max-width: 992px){
    .pm-grid::before, .pm-grid::after { display:none; }
  }

  /* ---- Quadrant cell ---- */
  .pm-cell {
    position: relative; z-index:1;
    background:#fff;
    border:1px solid #e9ecef;
    border-radius:14px;
    box-shadow:0 6px 16px rgba(0,0,0,.04);
    padding:12px;
    min-height: 420px;
    display:flex;
    flex-direction:column;
    gap:10px;
  }

  .pm-head {
    position: sticky;
    top: calc(var(--rails-header-offset, 0px));
    background:#f8f9fa;
    color:#212529;
    border:1px solid #e9ecef;
    border-radius:10px;
    padding:.5rem .75rem;
    font-weight:800;
    text-align:center;
    letter-spacing:.2px;
  }

  .pm-tiles {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 10px;
    align-content: start;
  }

  .pm-tile {
    --status:#6c757d;
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
    align-items: start;
    background: var(--status);
    color:#fff;
    border:1px solid transparent;
    border-radius:12px;
    box-shadow: 0 3px 10px rgba(0,0,0,.10);
    padding:10px 12px;
    min-height: 68px;
    text-shadow: 0 1px 0 rgba(0,0,0,.25);
  }
  .pm-tile .pm-strip { display:none; }

  .pm-code {
    font-size:.75rem;
    font-weight:800;
    letter-spacing:.3px;
    color:#fff;
    opacity:.95;
    margin-bottom:2px;
  }
  .pm-name {
    font-size:.82rem;
    line-height:1.25;
    color:#fff;
    word-break:break-word;
  }

  @@media print {
    .page-hero, .pm-toolbar { display:none !important; }
    .pm-wrap { padding:0; }
    .pm-cell { box-shadow:none; break-inside:avoid; }
  }
</style>

<div class="container pm-wrap">
  @section PageHeader {
    <div class="page-hero" style="background-image:url('@Url.Content("~/images/pic1.jpg")')">
      <div class="page-hero-content">
        <h1 class="page-title">@Localizer["PriorityMatrix"]</h1>
      </div>
    </div>
  }

  <div class="with-rails">
    <div class="pm-grid">
      @{
        var q1 = Model.Quadrants.FirstOrDefault(q => q.Quadrant == 1);
        var q2 = Model.Quadrants.FirstOrDefault(q => q.Quadrant == 2);
        var q3 = Model.Quadrants.FirstOrDefault(q => q.Quadrant == 3);
        var q4 = Model.Quadrants.FirstOrDefault(q => q.Quadrant == 4);
        var arr = new[]{ q1, q2, q3, q4 };
      }

      @foreach (var q in arr)
      {
        <section class="pm-cell">
          <header class="pm-head">@Localizer["Priority"] @q?.Quadrant</header>

          <div class="pm-tiles">
            @if (q?.Objectives?.Any() == true)
            {
              foreach (var o in q!.Objectives)
              {
                <article class="pm-tile" style="--status:@o.StatusColor">
                  <span class="pm-strip"></span>
                  <div>
                    <div class="pm-code">@o.ObjectiveCode</div>
                    <div class="pm-name">@o.ObjectiveName</div>
                  </div>
                </article>
              }
            }
            else
            {
              <div class="text-muted small">@Localizer["NoObjectives"]</div>
            }
          </div>
        </section>
      }
    </div>
  </div>
</div>