@model KPIMonitor.Models.LoginViewModel
@inject Microsoft.AspNetCore.Mvc.Localization.IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Login"];
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div id="login-page">
    <div class="login-container">
        <div class="login-box" role="main" aria-labelledby="login-header">
            <img src="~/images/logo-en.png" alt="@Localizer["CompanyLogo"]" class="login-logo" />
            <h2 id="login-header">@Localizer["SignIn"]</h2>

            @Html.ValidationSummary(excludePropertyErrors: true, message: "", htmlAttributes: new { @class = "text-danger mb-3" })

            @using (Html.BeginForm("Login", "Account", FormMethod.Post, new { id = "login-form" }))
            {
                @Html.AntiForgeryToken()

                <div class="form-group mb-3">
                    @Html.LabelFor(m => m.Username, Localizer["Username"].Value)
                    @Html.TextBoxFor(m => m.Username, new { @class = "form-control", autofocus = "autofocus", aria_required = "true" })
                    @Html.ValidationMessageFor(m => m.Username, "", new { @class = "text-danger" })
                </div>

                <div class="form-group mb-4">
                    @Html.LabelFor(m => m.Password, Localizer["Password"].Value)
                    @Html.PasswordFor(m => m.Password, new { @class = "form-control", aria_required = "true" })
                    @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                </div>

                <button type="submit" class="btn btn-primary btn-block w-100">@Localizer["LoginButton"]</button>
            }
        </div>
    </div>
</div>